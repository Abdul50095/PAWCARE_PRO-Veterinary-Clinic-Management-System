PORT=8000

# Local MySQL example.
# On Railway, the server also accepts MYSQLHOST, MYSQLPORT, MYSQLUSER,
# MYSQLPASSWORD, and MYSQLDATABASE from a Railway MySQL service.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=vet_clinic

# Comma-separated list. Leave blank to allow all origins while testing.
# For production, set this to your Vercel frontend URL, for example:
# CORS_ORIGIN=https://your-project.vercel.app
CORS_ORIGIN=http://localhost:8000,http://127.0.0.1:5178

# Login/auth settings. Change these before deployment.
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_SECONDS=28800
ALLOW_REGISTRATION=true
VERIFY_EMAIL_EXPIRES_SECONDS=86400
PUBLIC_APP_URL=http://127.0.0.1:5178

# Required for automated verification emails.
# Create a Resend API key and set a verified sender before deployment.
RESEND_API_KEY=
EMAIL_FROM=PawCare Pro <onboarding@resend.dev>

ADMIN_EMAIL=admin@pawcare.local
ADMIN_PASSWORD=replace_with_a_strong_admin_password
